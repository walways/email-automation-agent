# QQ 邮箱配置
# 请复制此文件为 .env 并填入实际值

# QQ 邮箱地址 (如：123456@qq.com)
QQ_EMAIL_USERNAME=

# QQ 邮箱授权码 (非登录密码，需在 QQ 邮箱设置中获取)
# 获取方式：QQ 邮箱网页版 -> 设置 -> 账户 -> 开启 IMAP/SMTP 服务 -> 生成授权码
QQ_EMAIL_AUTH_CODE=

# Claude API Key
# 获取方式：https://console.anthropic.com/
# 兼容说明：旧版本变量名为 ANTHROPIC_API_KEY，启动脚本会自动兼容
# provider=anthropic 时需要；provider=claude_code 可留空
ANTHROPIC_AUTH_TOKEN=

# 可选：Anthropic 兼容网关地址（provider=anthropic 时使用）
ANTHROPIC_BASE_URL=
