# QQ 邮箱配置
# 请复制此文件为 .env 并填入实际值

# QQ 邮箱地址 (如：123456@qq.com)
QQ_EMAIL_USERNAME=your-email@example.com

# QQ 邮箱授权码 (非登录密码，需在 QQ 邮箱设置中获取)
# 获取方式：QQ 邮箱网页版 -> 设置 -> 账户 -> 开启 IMAP/SMTP 服务 -> 生成授权码
QQ_EMAIL_AUTH_CODE=your-qq-auth-code

# 本地 LLM CLI 配置（仅本地模式）
# 可选: claude_code / codex
LLM_PROVIDER=claude_code
# 对应本地命令（claude_code -> claude, codex -> codex）
LLM_COMMAND=claude
